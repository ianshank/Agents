# Environment Variables — langfuse-eval-harness
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Langfuse — required for langfuse dataset source, sink, and tracing
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# NVIDIA Nemotron — required for the openai judge with NVIDIA backend
NVIDIA_API_KEY=

# OpenAI — required for the openai judge with OpenAI backend
OPENAI_API_KEY=

# LM Studio — local inference (no key needed, just URL)
# LM_STUDIO_URL=http://127.0.0.1:1234/v1

# Anthropic — required for the anthropic judge backend
ANTHROPIC_API_KEY=

# Eval engine — parallel execution (default: sequential)
# MAX_WORKERS=1

# Output directory for sinks (json_file, future html_report)
# OUT_DIR=./out

# Sampling rate for eval runs (0.0-1.0, default: 1.0)
# SAMPLE_RATE=1.0

# Judge score threshold (default: 0.6)
# JUDGE_THRESHOLD=0.6

# CLI timeout for E2E tests (seconds)
# E2E_CLI_TIMEOUT_SECONDS=300

# Calibrated merge gate (opt-in, requires audit labels)
# ENABLE_CALIBRATED_AUTOMERGE=
