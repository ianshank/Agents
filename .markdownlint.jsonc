{
  // Advisory config, non-blocking (docs.yml markdownlint job is continue-on-error).
  // Rules disabled below are ones the existing/vendored corpus pervasively uses; this
  // establishes a GREEN baseline so the advisory check flags *new* regressions instead of
  // drowning in pre-existing noise. Re-enable a rule as its backlog is cleaned up.
  "default": true,
  "MD013": false,   // line length — prose/tables run long by design
  "MD033": false,   // inline HTML — used in some docs
  "MD041": false,   // first line heading — badges/blockquotes lead some files
  "MD024": { "siblings_only": true },  // duplicate headings OK across sections
  "MD029": false,   // ordered-list numbering style
  "MD036": false,   // emphasis-as-heading (used in tables/notes)
  "MD031": false,   // blanks around fences — pervasive in vendored skills/*.md
  "MD032": false,   // blanks around lists — same
  "MD040": false,   // fenced code language — some vendored fences are bare
  "MD060": false    // table pipe spacing — the repo uses compact `|---|` tables
}
