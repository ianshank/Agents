{
  "//": "Template only — the plugin ships NO live MCP servers. Copy to .mcp.json in a consumer and fill via environment variables. Never commit credentials.",
  "mcpServers": {
    "example-internal-api": {
      "command": "${CLAUDE_PLUGIN_ROOT}/servers/example-server",
      "args": ["--endpoint", "${EXAMPLE_API_ENDPOINT}"],
      "env": {
        "EXAMPLE_API_TOKEN": "${EXAMPLE_API_TOKEN}"
      }
    }
  }
}
