# Coverage gate for the operational scripts (validate, select_next, init,
# regression_gate, skill_marketplace, drift/protected-path checks, ...).
# scripts/validations/F_* are themselves one-shot CI gates executed via
# features.yaml validation commands — they are checks, not unit-test targets —
# so they are excluded here (quality-gates.yml measures the phase-2 ones directly).
[run]
branch = True
omit =
    */scripts/validations/*
    # One-shot migrations (e.g. agent_domain_backfill) are dated operational
    # scripts, not reusable units — same rationale as validations above. Their
    # pure logic is still tested (tests/test_agent_domain_backfill.py).
    */scripts/migrations/*

[report]
fail_under = 85
show_missing = True
exclude_lines =
    pragma: no cover
    if __name__ ==
    if TYPE_CHECKING:
    raise NotImplementedError
    @(abc\.)?abstractmethod
    ^\s*\.\.\.$
