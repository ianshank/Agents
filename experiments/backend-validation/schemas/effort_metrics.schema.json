{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "backend-validation/effort_metrics.schema.json",
  "title": "effort_metrics.json",
  "description": "Ops-burden evidence captured at deploy time (spec R9) plus L2 adapter-delta metrics (spec R1). Written by backend_validation.metrics; consumed verbatim by the P5 report — numbers are evidence, never judgments.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "backends"],
  "properties": {
    "schema_version": {"const": 1},
    "backends": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/backendMetrics"}
    },
    "adapter_delta": {
      "type": "array",
      "items": {"$ref": "#/$defs/adapterDelta"}
    }
  },
  "$defs": {
    "backendMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend",
        "setup_wall_clock_seconds",
        "health_retries",
        "container_count",
        "images",
        "all_images_pinned"
      ],
      "properties": {
        "backend": {"type": "string"},
        "setup_wall_clock_seconds": {"type": "number", "minimum": 0},
        "health_retries": {"type": "integer", "minimum": 0},
        "container_count": {"type": "integer", "minimum": 0},
        "idle_cpu_percent_median": {"type": ["number", "null"], "minimum": 0},
        "idle_ram_mb_median": {"type": ["number", "null"], "minimum": 0},
        "disk_bytes": {"type": ["integer", "null"], "minimum": 0},
        "images": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "pinned"],
            "properties": {
              "name": {"type": "string"},
              "digest": {"type": ["string", "null"], "pattern": "^sha256:[0-9a-f]{64}$"},
              "pinned": {"type": "boolean"}
            }
          }
        },
        "all_images_pinned": {"type": "boolean"},
        "started_utc": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "adapterDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["backend", "adapter_files", "adapter_loc", "conformance_passed", "conformance_total"],
      "properties": {
        "backend": {"type": "string"},
        "adapter_files": {"type": "integer", "minimum": 0},
        "adapter_loc": {"type": "integer", "minimum": 0},
        "conformance_passed": {"type": "integer", "minimum": 0},
        "conformance_total": {"type": "integer", "minimum": 0},
        "mapping_gaps": {"type": "array", "items": {"type": "string"}},
        "per_operation_latency_ms": {
          "type": "object",
          "additionalProperties": {"type": "number", "minimum": 0}
        }
      }
    }
  }
}
