# Copy to .env.local (gitignored) and fill in. PLACEHOLDERS ONLY in this file — never
# commit a real value anywhere in this repo (leaked-key precedent: see the credential-scrub
# phase of docs/plans/agents-critical-path/PLAN.md). Values deliberately do NOT imitate
# real key shapes so the committed-secret grep test can stay maximally strict.

# --- Langfuse (created by the stack's headless init on first `make deploy`) ---
BV_LANGFUSE_SECRET_KEY=__set_me__
BV_LANGFUSE_PUBLIC_KEY=__set_me__
# BV_LANGFUSE_PORT=18321

# --- Opik ---
BV_OPIK_API_KEY=__set_me__
# BV_OPIK_PORT=18322

# --- Local judge (OpenAI-compatible; most servers accept any non-empty key) ---
BV_JUDGE_API_KEY=__set_me__
# BV_JUDGE_PORT=18323
# BV_JUDGE_MODEL=llama3.2:3b

# --- Optional knobs (defaults in config.yaml) ---
# BV_OP_TIMEOUT_SECONDS=30
# BV_PROBE_BUDGET_SECONDS=300
# BV_RETRY_MAX_ATTEMPTS=3
# BV_RETRY_BACKOFF_SECONDS=2
# BV_MIN_FREE_GB=20
